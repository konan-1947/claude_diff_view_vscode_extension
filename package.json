{
  "name": "claude-diff-view",
  "displayName": "Claude Diff View",
  "description": "Run Claude Code sessions with inline diff review",
  "version": "0.0.1",
  "publisher": "local-dev",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-diff-view",
          "title": "Claude Diff View",
          "icon": "media/claude-icon.svg"
        }
      ]
    },
    "views": {
      "claude-diff-view": [
        {
          "id": "claude-diff-view.session",
          "name": "Session"
        }
      ]
    },
    "commands": [
      {
        "command": "claude-diff-view.startSession",
        "title": "Claude: Start Session"
      },
      {
        "command": "claude-diff-view.acceptFile",
        "title": "Claude: Accept Changes",
        "icon": "$(check)"
      },
      {
        "command": "claude-diff-view.revertFile",
        "title": "Claude: Revert Changes",
        "icon": "$(discard)"
      },
      {
        "command": "claude-diff-view.installHooks",
        "title": "Claude: Install CLI Hooks (enable diff for terminal claude)"
      }
    ],
    "keybindings": [
      {
        "command": "claude-diff-view.startSession",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "claude-diff-view.acceptFile",
          "when": "isInDiffEditor",
          "group": "navigation@1"
        },
        {
          "command": "claude-diff-view.revertFile",
          "when": "isInDiffEditor",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
