{
  "name": "ai-cli-diff-view",
  "displayName": "AI CLI diff view",
  "description": "Inline diff review for AI CLI edits, best with Claude, Codex, and Qwen",
  "version": "2.0.1",
  "publisher": "konan1947",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/konan-1947/claude_diff_view_vscode_extension.git"
  },
  "bugs": {
    "url": "https://github.com/konan-1947/claude_diff_view_vscode_extension/issues"
  },
  "homepage": "https://github.com/konan-1947/claude_diff_view_vscode_extension#readme",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-cli-diff-view-terminal",
          "title": "AI CLI",
          "icon": "media/claude-icon.svg"
        }
      ]
    },
    "views": {
      "ai-cli-diff-view-terminal": [
        {
          "id": "ai-cli-diff-view.terminal",
          "name": "AI CLI",
          "type": "webview"
        }
      ],
      "explorer": [
        {
          "id": "ai-cli-diff-view.navBar",
          "name": "AI CLI Diff",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "ai-cli-diff-view.startSession",
        "title": "AI CLI Diff: Start Claude Session"
      },
      {
        "command": "ai-cli-diff-view.acceptAllHunks",
        "title": "AI CLI Diff: Accept All Changes"
      },
      {
        "command": "ai-cli-diff-view.acceptAllChanges",
        "title": "AI CLI Diff: Accept All Changes (All Files)"
      },
      {
        "command": "ai-cli-diff-view.revertAllHunks",
        "title": "AI CLI Diff: Revert All Changes"
      },
      {
        "command": "ai-cli-diff-view.acceptHunk",
        "title": "AI CLI Diff: Accept Hunk"
      },
      {
        "command": "ai-cli-diff-view.revertHunk",
        "title": "AI CLI Diff: Revert Hunk"
      },
      {
        "command": "ai-cli-diff-view.installHooks",
        "title": "AI CLI Diff: Install Claude CLI Hooks",
        "icon": "$(plug)"
      },
      {
        "command": "ai-cli-diff-view.openPendingFile",
        "title": "AI CLI Diff: Open Pending File"
      },
      {
        "command": "ai-cli-diff-view.nextFile",
        "title": "AI CLI Diff: Next Edited File"
      },
      {
        "command": "ai-cli-diff-view.prevFile",
        "title": "AI CLI Diff: Previous Edited File"
      }
    ],
    "keybindings": [
      {
        "command": "ai-cli-diff-view.startSession",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "ai-cli-diff-view.acceptAllHunks",
        "key": "ctrl+shift+y",
        "mac": "cmd+shift+y"
      },
      {
        "command": "ai-cli-diff-view.revertAllHunks",
        "key": "ctrl+shift+z",
        "mac": "cmd+shift+z"
      },
      {
        "command": "ai-cli-diff-view.prevFile",
        "key": "alt+h",
        "when": "ai-cli-diff-view.hasPendingDiff"
      },
      {
        "command": "ai-cli-diff-view.nextFile",
        "key": "alt+l",
        "when": "ai-cli-diff-view.hasPendingDiff"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "ai-cli-diff-view.acceptAllHunks",
          "when": "ai-cli-diff-view.hasPendingDiff",
          "group": "navigation@1"
        },
        {
          "command": "ai-cli-diff-view.revertAllHunks",
          "when": "ai-cli-diff-view.hasPendingDiff",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "material-icon-theme": "^5.32.0",
    "node-pty": "^1.2.0-beta.13"
  }
}
